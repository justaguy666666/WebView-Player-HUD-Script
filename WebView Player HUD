local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local MAX_DISTANCE = 40

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "WebView"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = LocalPlayer.PlayerGui

local Portrait = Instance.new("ImageLabel")
Portrait.Size = UDim2.fromOffset(80,80)
Portrait.AnchorPoint = Vector2.new(0.5, 0.5)
Portrait.BackgroundTransparency = 1
Portrait.ImageTransparency = 1 
Portrait.ZIndex = 3
Portrait.Parent = ScreenGui

local PortraitCorner = Instance.new("UICorner")
PortraitCorner.CornerRadius = UDim.new(1,0)
PortraitCorner.Parent = Portrait

local lastPortraitId = nil
local INFO_COUNT = 6
local InfoContainers = {}
local InfoLabels = {}
local Lines = {}

for i = 1, INFO_COUNT do
    local c = Instance.new("Frame")
    c.Size = UDim2.fromOffset(180, 22)
    c.AnchorPoint = Vector2.new(0.5, 0.5)
    c.BackgroundTransparency = 1
    c.Visible = false
    c.ZIndex = 2
    c.Parent = ScreenGui

    local bar = Instance.new("Frame")
    bar.Size = UDim2.fromOffset(180, 22)
    bar.BackgroundColor3 = Color3.fromRGB(20,20,20)
    bar.BackgroundTransparency = 0.2
    bar.BorderSizePixel = 0
    bar.ZIndex = 2
    bar.Parent = c

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0,6)
    corner.Parent = bar

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -10, 1, 0)
    label.Position = UDim2.fromOffset(5,0)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.GothamMedium
    label.TextSize = 12
    label.TextColor3 = Color3.new(1,1,1)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.ZIndex = 3
    label.TextTransparency = 1 
    label.Parent = bar

    InfoContainers[i] = c
    InfoLabels[i] = label
end

local function AnimateIn(guiObject, props, duration)
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local tween = TweenService:Create(guiObject, tweenInfo, props)
    tween:Play()
end

local function AnimateOut(guiObject, props, duration)
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
    local tween = TweenService:Create(guiObject, tweenInfo, props)
    tween:Play()
end

local function FindNearestPlayer()
    local Character = LocalPlayer.Character
    if not Character then return nil end

    local Root = Character:FindFirstChild("HumanoidRootPart")
    if not Root then return nil end

    local Closest
    local ClosestDistance = MAX_DISTANCE

    for _,Player in ipairs(Players:GetPlayers()) do
        if Player ~= LocalPlayer then
            local Char = Player.Character
            local TheirRoot = Char and Char:FindFirstChild("HumanoidRootPart")

            if TheirRoot then
                local Distance = (Root.Position - TheirRoot.Position).Magnitude
                if Distance < ClosestDistance then
                    ClosestDistance = Distance
                    Closest = Player
                end
            end
        end
    end

    return Closest, ClosestDistance
end

local uiVisible = false

RunService.RenderStepped:Connect(function()
    local Target, Distance = FindNearestPlayer()

    if not Target then
        if uiVisible then
            uiVisible = false
            AnimateOut(Portrait, {ImageTransparency = 1}, 0.15)

            for i = 1, INFO_COUNT do
                local box = InfoContainers[i]
                local label = InfoLabels[i]
                local tweenInfo = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.In)

                TweenService:Create(box, tweenInfo, {BackgroundTransparency = 1}):Play()
                TweenService:Create(label, tweenInfo, {TextTransparency = 1}):Play()

                if Lines[i] then
                    TweenService:Create(Lines[i], tweenInfo, {BackgroundTransparency = 1}):Play()
                end

                boxTween = TweenService:Create(box, tweenInfo, {BackgroundTransparency = 1})
                boxTween:Play()
                boxTween.Completed:Once(function()
                    box.Visible = false
                    label.Visible = false
                    if Lines[i] then Lines[i].Visible = false end
                end)
            end
        end
        return
    end

    local Character = Target.Character
    local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
    local Root = Character and Character:FindFirstChild("HumanoidRootPart")
    if not (Humanoid and Root) then return end

    if Target.UserId ~= lastPortraitId then
        lastPortraitId = Target.UserId
        local thumb = Players:GetUserThumbnailAsync(Target.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420)
        Portrait.Image = thumb
    end

    InfoLabels[1].Text = "Display: " .. Target.DisplayName
    InfoLabels[2].Text = "Username: @" .. Target.Name
    InfoLabels[3].Text = "User ID: " .. Target.UserId
    InfoLabels[4].Text = "Age: " .. Target.AccountAge .. " days"
    InfoLabels[5].Text = "Health: " .. math.floor(Humanoid.Health) .. "/" .. Humanoid.MaxHealth
    InfoLabels[6].Text = string.format("Distance: %.1f m", Distance)

    local screenPos, visible = Camera:WorldToViewportPoint(Root.Position)
    if not visible then return end

    if not uiVisible then
        uiVisible = true
        Portrait.Visible = true
        AnimateIn(Portrait, {ImageTransparency = 0}, 0.15)

        for i = 1, INFO_COUNT do
            local box = InfoContainers[i]
            local label = InfoLabels[i]
            local tweenInfo = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

            box.Visible = true
            label.Visible = true
            TweenService:Create(box, tweenInfo, {BackgroundTransparency = 0}):Play()
            TweenService:Create(label, tweenInfo, {TextTransparency = 0}):Play()

            if Lines[i] then
                Lines[i].Visible = true
                TweenService:Create(Lines[i], tweenInfo, {BackgroundTransparency = 0.25}):Play()
            end
        end
    end

    Portrait.Position = UDim2.fromOffset(screenPos.X, screenPos.Y)

    local radius = 160
    local positions = {
        Vector2.new(0, -radius * 1.2),
        Vector2.new(-radius, -radius * 0.5),
        Vector2.new(radius, -radius * 0.5),
        Vector2.new(-radius, radius * 0.5),
        Vector2.new(radius, radius * 0.5),
        Vector2.new(0, radius * 1.3),
    }

    if not Lines then Lines = {} end
    for i = 1, INFO_COUNT do
        if not Lines[i] then
            local ln = Instance.new("Frame")
            ln.Name = "Line_" .. i
            ln.AnchorPoint = Vector2.new(.5,.5)
            ln.BorderSizePixel = 0
            ln.BackgroundColor3 = Color3.fromRGB(255,255,255)
            ln.BackgroundTransparency = 1 
            ln.ZIndex = 1
            ln.Size = UDim2.fromOffset(0,2)
            ln.Parent = ScreenGui
            Lines[i] = ln

            TweenService:Create(ln, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 0.25}):Play()
            ln.Visible = true
        end
    end

    for i = 1, INFO_COUNT do
        local box = InfoContainers[i]
        local label = InfoLabels[i]
        local offset = positions[i]
        local hover = math.sin(tick() * 0.5) * 6

        local x = screenPos.X + offset.X
        local y = screenPos.Y + offset.Y + hover

        box.Position = UDim2.fromOffset(x, y)

        local startPos = Vector2.new(box.AbsolutePosition.X + box.AbsoluteSize.X * 0.5, box.AbsolutePosition.Y + box.AbsoluteSize.Y * 0.5)
        local endPos = Vector2.new(Portrait.AbsolutePosition.X + Portrait.AbsoluteSize.X * 0.5, Portrait.AbsolutePosition.Y + Portrait.AbsoluteSize.Y * 0.5)
        local diff = endPos - startPos
        local length = diff.Magnitude

        local ln = Lines[i]
        ln.Size = UDim2.fromOffset(length, 2)
        ln.Position = UDim2.fromOffset((startPos.X + endPos.X) * 0.5, (startPos.Y + endPos.Y) * 0.5)
        ln.Rotation = math.deg(math.atan2(diff.Y, diff.X))
    end
end)
