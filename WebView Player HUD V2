local function AnimateIn(guiObject, props, duration)
    TweenService:Create(guiObject, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
end

local function AnimateOut(guiObject, props, duration)
    TweenService:Create(guiObject, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.In), props):Play()
end

local function PulseScan()
    local pulse = Instance.new("Frame")
    pulse.Size = UDim2.fromOffset(MIN_SIZE, MIN_SIZE)
    pulse.AnchorPoint = Vector2.new(0.5, 0.5)
    pulse.Position = Portrait.Position
    pulse.BackgroundColor3 = ActiveTheme.Primary
    pulse.BackgroundTransparency = 0.7
    pulse.ZIndex = 1
    pulse.Parent = ScreenGui

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0)
    corner.Parent = pulse

    TweenService:Create(
        pulse,
        TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        {Size = UDim2.fromOffset(MAX_SIZE + 40, MAX_SIZE + 40), BackgroundTransparency = 1}
    ):Play()

    task.delay(0.5, function()
        pulse:Destroy()
    end)
end

local function FindNearestPlayer()
    local Character = LocalPlayer.Character
    if not Character then return nil end

    local Root = Character:FindFirstChild("HumanoidRootPart")
    if not Root then return nil end

    local Closest
    local ClosestDistance = MAX_DISTANCE

    for _, Player in ipairs(Players:GetPlayers()) do
        if Player ~= LocalPlayer then
            local Char = Player.Character
            local TheirRoot = Char and Char:FindFirstChild("HumanoidRootPart")

            if TheirRoot then
                local Distance = (Root.Position - TheirRoot.Position).Magnitude
                if Distance < ClosestDistance then
                    ClosestDistance = Distance
                    Closest = Player
                end
            end
        end
    end

    return Closest, ClosestDistance
end

local uiVisible = false
local lastTarget = nil

RunService.RenderStepped:Connect(function()
    local Target, Distance = FindNearestPlayer()

    if not Target then
        if uiVisible then
            uiVisible = false
            AnimateOut(BlurEffect, {Size = 0}, 0.2)
            AnimateOut(Portrait, {ImageTransparency = 1}, 0.15)
            Portrait.Visible = false
            PortraitShadow.Visible = false

            for i = 1, INFO_COUNT do
                InfoContainers[i].Visible = false
                InfoLabels[i].Visible = false
                CurvedLines[i].Visible = false
            end
        end
        return
    end

    local Character = Target.Character
    local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
    local Root = Character and Character:FindFirstChild("HumanoidRootPart")
    if not (Humanoid and Root) then return end

    if Target ~= lastTarget then
        lastTarget = Target
        lastPortraitId = Target.UserId
        local thumb = Players:GetUserThumbnailAsync(Target.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420)
        Portrait.Image = thumb

        if uiVisible then
            PulseScan()
        end
    end

    InfoLabels[1].Text = "Display: " .. Target.DisplayName
    InfoLabels[2].Text = "Username: @" .. Target.Name
    InfoLabels[3].Text = "User ID: " .. Target.UserId
    InfoLabels[4].Text = "Age: " .. Target.AccountAge .. " days"
    InfoLabels[5].Text = "Health: " .. math.floor(Humanoid.Health) .. "/" .. Humanoid.MaxHealth
    InfoLabels[6].Text = string.format("Distance: %.1f m", Distance)

    local screenPos, visible = Camera:WorldToViewportPoint(Root.Position)
    if not visible then return end

    if not uiVisible then
        uiVisible = true
        AnimateIn(BlurEffect, {Size = 4}, 0.2)
        Portrait.Visible = true
        PortraitShadow.Visible = true
        AnimateIn(Portrait, {ImageTransparency = 0}, 0.15)

        for i = 1, INFO_COUNT do
            local box = InfoContainers[i]
            local label = InfoLabels[i]

            box.Visible = true
            label.Visible = true

            AnimateIn(box, {BackgroundTransparency = 0}, 0.15)
            AnimateIn(label, {TextTransparency = 0}, 0.15)
        end
    end

    local adjustedDistance = math.max(0, Distance - START_SCALE)
    local scale = math.clamp(adjustedDistance / SCALE_DISTANCE, 0, 1)
    local newSize = MIN_SIZE + (MAX_SIZE - MIN_SIZE) * scale

    Portrait.Size = UDim2.fromOffset(newSize, newSize)
    PortraitShadow.Size = UDim2.fromOffset(newSize + 40, newSize + 40)

    Portrait.Position = UDim2.fromOffset(screenPos.X, screenPos.Y)
    PortraitShadow.Position = Portrait.Position

    if ActiveTheme.Mode == "Animated" then
        local t = tick()
        local col = ActiveTheme.Animation(t)

        PortraitStroke.Color = col

        for i = 1, INFO_COUNT do
            local bar = InfoContainers[i]:FindFirstChildOfClass("Frame")
            if bar then
                local stroke = bar:FindFirstChildOfClass("UIStroke")
                if stroke then stroke.Color = col end

                local grad = bar:FindFirstChildOfClass("UIGradient")
                if grad then
                    grad.Color = ColorSequence.new({
                        ColorSequenceKeypoint.new(0, col:lerp(Color3.new(0,0,0), 0.4)),
                        ColorSequenceKeypoint.new(1, col:lerp(Color3.new(0,0,0), 0.7))
                    })
                end
            end
        end
    end

    local radius = 160
    local positions = {
        Vector2.new(0, -radius * 1.2),
        Vector2.new(-radius, -radius * 0.5),
        Vector2.new(radius, -radius * 0.5),
        Vector2.new(-radius, radius * 0.5),
        Vector2.new(radius, radius * 0.5),
        Vector2.new(0, radius * 1.3),
    }

    for i = 1, INFO_COUNT do
        local box = InfoContainers[i]
        local label = InfoLabels[i]
        local curve = CurvedLines[i]

        local offset = positions[i]

        local hover = math.sin(tick() * 0.5 + i) * 6
        local rot = math.sin(tick() * 0.7 + i) * 1.5

        local x = screenPos.X + offset.X
        local y = screenPos.Y + offset.Y + hover

        box.Position = UDim2.fromOffset(x, y)
        box.Rotation = rot

        local startPos = Vector2.new(
            box.AbsolutePosition.X + box.AbsoluteSize.X * 0.5,
            box.AbsolutePosition.Y + box.AbsoluteSize.Y * 0.5
        )
        local endPos = Vector2.new(
            Portrait.AbsolutePosition.X + Portrait.AbsoluteSize.X * 0.5,
            Portrait.AbsolutePosition.Y + Portrait.AbsoluteSize.Y * 0.5
        )

        local midPos = (startPos + endPos) / 2 + Vector2.new(0, -40)

        curve.Visible = true
        curve:ClearAllChildren()

        local col = (ActiveTheme.Mode == "Animated")
            and ActiveTheme.Animation(tick())
            or ActiveTheme.Line

        local function drawSegment(a, b)
            local seg = Instance.new("Frame")
            seg.BackgroundColor3 = col
            seg.BorderSizePixel = 0
            seg.Size = UDim2.fromOffset((b - a).Magnitude, 2)
            seg.AnchorPoint = Vector2.new(0.5, 0.5)
            seg.Position = UDim2.fromOffset((a.X + b.X) / 2, (a.Y + b.Y) / 2)
            seg.Rotation = math.deg(math.atan2(b.Y - a.Y, b.X - a.X))
            seg.BackgroundTransparency = 0.25
            seg.Parent = curve
        end

        drawSegment(startPos, midPos)
        drawSegment(midPos, endPos)
    end
end)
